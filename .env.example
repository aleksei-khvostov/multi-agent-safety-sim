# LLM API Keys (never commit real keys)
XAI_API_KEY=replace-with-your-xai-api-key
OPENAI_API_KEY=replace-with-your-openai-api-key
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key
# For local models
OLLAMA_BASE_URL=http://localhost:11434
# Or use litellm proxy
LITELLM_PROXY_URL=

# Safety defaults (override in config)
SAFETY_MAX_TOKENS_PER_RUN=50000
SAFETY_MAX_STEPS=200
